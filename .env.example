# Copy to .env and fill in real values before running anything.
# `docker compose up -d` starts a local Postgres matching these defaults.

DATABASE_URL="postgresql://app:app@localhost:5432/project_mgmt"

# NextAuth v5 — generate with: npx auth secret
AUTH_SECRET="replace-with-a-random-32-byte-secret"

# Encrypts SMTP passwords and AI provider API keys at rest (lib/crypto-secrets.ts).
# Must be a base64-encoded 32-byte key. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="replace-with-a-random-base64-32-byte-key"

# Base URL of the Next.js app itself (used to build invite links, CORS on
# the socket server, etc). Change the port if you run `next dev -p <port>`.
APP_URL="http://localhost:3000"

# Standalone Socket.io server (realtime/socket-server.ts), run separately
# via `npm run socket`.
SOCKET_PORT=4001
NEXT_PUBLIC_WS_URL="http://localhost:4001"

# Local super-admin seed (scripts/seed-superadmin.ts, run via `npm run db:seed`).
# Do NOT put real credentials here — this file is committed. Set the real
# values in your gitignored .env only.
SEED_SUPERADMIN_EMAIL=""
SEED_SUPERADMIN_PASSWORD=""
SEED_SUPERADMIN_NAME=""

# Local-disk root for per-engagement file uploads (services/project-files.ts,
# lib/file-storage.ts). Relative paths resolve against the app's cwd; point
# this at a mounted volume in production. Gitignored by default.
UPLOADS_DIR="./uploads"
